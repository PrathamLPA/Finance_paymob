# Application
APP_NAME=Finance Automation
APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+psycopg://finance:finance@localhost:5432/finance_automation

# Integrations (mock by default for prototype)
USE_MOCK_INTEGRATIONS=true

# Bitrix24
BITRIX24_WEBHOOK_URL=
BITRIX_WEBHOOK_SECRET=
BITRIX_LEAD_PAYMENT_STAGE_ID=LEAD_PAYMENT
BITRIX_FINANCE_GENERATE_LINK_STAGE_ID=FINANCE_GENERATE_LINK
BITRIX_SALES_PIPELINE_ID=
BITRIX_FINANCE_PIPELINE_ID=
BITRIX_B2C_PIPELINE_ID=
BITRIX_FIELD_INVOICE_REFERENCE=UF_CRM_INVOICE_REFERENCE
BITRIX_FIELD_INVOICE_URL=UF_CRM_INVOICE_URL
BITRIX_FIELD_AMOUNT_PAID=UF_CRM_AMOUNT_PAID
BITRIX_FIELD_REMAINING_BALANCE=UF_CRM_REMAINING_BALANCE
BITRIX_FIELD_TOTAL_AMOUNT=UF_CRM_TOTAL_AMOUNT

# Paymob
PAYMOB_API_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_INTEGRATION_ID=0
PAYMOB_HMAC_SECRET=
# Regional API host: https://uae.paymob.com (UAE), https://accept.paymob.com (Egypt), https://ksa.paymob.com (KSA)
PAYMOB_BASE_URL=https://uae.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://uae.paymob.com/unifiedcheckout/

# Zoho Books
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_BOOKS_API_URL=https://www.zohoapis.com/books/v3

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=finance@example.com
SENDGRID_FROM_NAME=Finance Team

# Workflow
TERMS_VERSION=1.1
REFUND_POLICY_URL=https://learnerspoint.org/refund-policy
PAYMENT_SESSION_TTL_HOURS=72
DEFAULT_CURRENCY=AED
STORAGE_PATH=storage
