# Copy ALL of these into Railway → Backend service → Variables
# (The 4 URL vars alone are not enough — you also need DATABASE_URL + Paymob + Bitrix)

PUBLIC_BASE_URL=https://b2c-finance-and-ops-backend-production.up.railway.app
PAYMENT_FRONTEND_BASE_URL=https://financepaymob-frontend-production.up.railway.app
FRONTEND_ORIGIN=https://financepaymob-frontend-production.up.railway.app

DATABASE_URL=<your-supabase-pooler-url>
USE_MOCK_INTEGRATIONS=false

BITRIX24_WEBHOOK_URL=<from-local-.env>
BITRIX_WEBHOOK_SECRET=<from-local-.env>
BITRIX_FINANCE_GENERATE_LINK_STAGE_ID=C38:1
BITRIX_FINANCE_THRESHOLD_MET_STAGE_ID=<stage-id-after-required-payment>
BITRIX_FIELD_PAYMENT_LINK=UF_CRM_1783502165006
BITRIX_FIELD_CUSTOMER_EMAIL=UF_CRM_1724931551
BITRIX_FIELD_PAYMENT_PERCENTAGE=<optional-uf-field>
BITRIX_FIELD_PAYMENT_STATUS=<optional-uf-field>
BITRIX_FIELD_TRANSACTION_ID=<optional-uf-field>

PAYMOB_SECRET_KEY=<from-local-.env>
PAYMOB_PUBLIC_KEY=<from-local-.env>
PAYMOB_INTEGRATION_ID=45192
PAYMOB_HMAC_SECRET=<from-local-.env>
PAYMOB_BASE_URL=https://uae.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://uae.paymob.com/unifiedcheckout/

ZOHO_CLIENT_ID=<optional>
ZOHO_CLIENT_SECRET=<optional>
ZOHO_REFRESH_TOKEN=<optional>
ZOHO_ORGANIZATION_ID=<optional>

SENDGRID_API_KEY=<optional>
SENDGRID_FROM_EMAIL=finance@example.com
SENDGRID_FROM_NAME=Finance Team

DEFAULT_CURRENCY=AED
TERMS_VERSION=1.1
STORAGE_PATH=/tmp/finance-storage
PAYMENT_REQUIRED_PERCENT=50
REMINDER_ENABLED=true
REMINDER_INTERVAL_HOURS=24
REMINDER_SCHEDULER_ENABLED=true

# Frontend service — only this one:
# API_BASE_URL=https://b2c-finance-and-ops-backend-production.up.railway.app
