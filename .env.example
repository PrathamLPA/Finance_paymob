# Application
APP_NAME=Finance Automation
APP_ENV=development
LOG_LEVEL=INFO

# Backend API public URL (Bitrix outbound webhook + Paymob notification_url)
PUBLIC_BASE_URL=http://localhost:8001

# Frontend payment pages (customer links + Paymob redirect thank-you)
PAYMENT_FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Frontend service only — URL of the backend API
API_BASE_URL=http://127.0.0.1:8001

# Database
DATABASE_URL=postgresql+psycopg://finance:finance@localhost:5432/finance_automation

# Integrations (mock by default for prototype)
USE_MOCK_INTEGRATIONS=true

# Bitrix24
BITRIX24_WEBHOOK_URL=
BITRIX_WEBHOOK_SECRET=
BITRIX_LEAD_PAYMENT_STAGE_ID=LEAD_PAYMENT
BITRIX_FINANCE_GENERATE_LINK_STAGE_ID=FINANCE_GENERATE_LINK
BITRIX_SALES_PIPELINE_ID=
BITRIX_FINANCE_PIPELINE_ID=
BITRIX_B2C_PIPELINE_ID=
BITRIX_FIELD_INVOICE_REFERENCE=UF_CRM_INVOICE_REFERENCE
BITRIX_FIELD_INVOICE_URL=UF_CRM_INVOICE_URL
BITRIX_FIELD_AMOUNT_PAID=UF_CRM_AMOUNT_PAID
BITRIX_FIELD_REMAINING_BALANCE=UF_CRM_REMAINING_BALANCE
BITRIX_FIELD_TOTAL_AMOUNT=UF_CRM_TOTAL_AMOUNT
BITRIX_FIELD_PAYMENT_LINK=UF_CRM_PAYMENT_LINK
BITRIX_FIELD_CUSTOMER_EMAIL=UF_CRM_CUSTOMER_EMAIL
BITRIX_FIELD_PAYMENT_PERCENTAGE=UF_CRM_PAYMENT_PERCENTAGE
BITRIX_FIELD_PAYMENT_STATUS=UF_CRM_PAYMENT_STATUS
BITRIX_FIELD_TRANSACTION_ID=UF_CRM_TRANSACTION_ID
BITRIX_FIELD_CUSTOMER_PHONE=UF_CRM_CUSTOMER_PHONE
BITRIX_FIELD_CUSTOMER_NAME=UF_CRM_CUSTOMER_NAME
BITRIX_FINANCE_THRESHOLD_MET_STAGE_ID=FINANCE_THRESHOLD_MET

# Paymob
PAYMOB_API_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_INTEGRATION_ID=0
PAYMOB_HMAC_SECRET=
PAYMOB_BASE_URL=https://uae.paymob.com
PAYMOB_CHECKOUT_BASE_URL=https://uae.paymob.com/unifiedcheckout/

# Zoho Books
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_BOOKS_API_URL=https://www.zohoapis.com/books/v3
ZOHO_DEFAULT_ITEM_ID=

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=finance@example.com
SENDGRID_FROM_NAME=Finance Team

# Workflow
TERMS_VERSION=1.1
REFUND_POLICY_URL=https://learnerspoint.org/refund-policy
PAYMENT_SESSION_TTL_HOURS=72
DEFAULT_CURRENCY=AED
STORAGE_PATH=storage
PAYMENT_REQUIRED_PERCENT=50
REMINDER_ENABLED=true
REMINDER_INTERVAL_HOURS=24
REMINDER_SCHEDULER_ENABLED=true
REMINDER_SCHEDULER_POLL_SECONDS=300
